# ATP Platform — Environment Variables
#
# Copy to .env and fill in your values:
#   cp .env.example .env
#
# Shell variables take priority over .env values.

# ── LLM API Keys ─────────────────────────────────────────────
# At least one is required for LLM-judge evaluations and test generation.

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=

# Alternative: use ATP-prefixed versions (same effect via pydantic-settings)
# ATP_OPENAI_API_KEY=
# ATP_ANTHROPIC_API_KEY=

# ── R-07 pipe-check spawner keys (method/run_pipe_check.py agents) ────
# Each <PREFIX>_API_KEY pairs with a registered agent. HOST/MODEL have
# registry/shim defaults, so usually only the key is needed here.
# MiMo (Xiaomi) — OpenAI-compatible endpoint
MIMO_API_KEY=
# MIMO_HOST=https://token-plan-sgp.xiaomimimo.com/v1
# Qwen (DashScope) — OpenAI-compatible endpoint
QWEN_API_KEY=
# QWEN_HOST=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# (mainland China: https://dashscope.aliyuncs.com/compatible-mode/v1)
# opencode → GLM (Zhipu) provider — Tier-2 (name provisional until the
# opencode CLI shim lands; opencode may instead use `opencode auth login`)
OPENCODE_GLM_API_KEY=
# codex_cli uses OPENAI_API_KEY; anthropic_api uses ANTHROPIC_API_KEY;
# claude_code and pi authenticate via their own CLI session (no key here).

# ── Core Settings ────────────────────────────────────────────

# Log level: DEBUG, INFO, WARNING, ERROR
ATP_LOG_LEVEL=INFO

# Number of parallel test workers
ATP_PARALLEL_WORKERS=4

# Default test execution timeout (seconds)
ATP_DEFAULT_TIMEOUT=300

# Stop on first test failure
ATP_FAIL_FAST=false

# Enable sandbox isolation for test execution
ATP_SANDBOX_ENABLED=false

# Default number of runs per test
ATP_RUNS_PER_TEST=1

# Environment: development, staging, production
ATP_ENV=development

# ── LLM Configuration (for test generation) ──────────────────

# Override LLM for atp generate command
ATP_LLM_API_KEY=
ATP_LLM_BASE_URL=https://api.openai.com/v1
ATP_LLM_MODEL=gpt-4o-mini

# ── Dashboard ────────────────────────────────────────────────

ATP_DASHBOARD_HOST=127.0.0.1
ATP_DASHBOARD_PORT=8080
ATP_DASHBOARD_DEBUG=false

# REQUIRED in production — change from default!
ATP_DASHBOARD_SECRET_KEY=

# Comma-separated allowed origins. Use specific origins in production.
ATP_DASHBOARD_CORS_ORIGINS=*

# ── Database ─────────────────────────────────────────────────

# SQLite (default) or PostgreSQL/MySQL connection string
# Leave commented out for default: ~/.atp/dashboard.db
# (a blank ATP_DATABASE_URL= is treated as unset, but commenting is clearer)
# ATP_DATABASE_URL=
ATP_DATABASE_ECHO=false

# ── Telemetry (OpenTelemetry) ────────────────────────────────

ATP_TELEMETRY_ENABLED=false
ATP_TELEMETRY_SERVICE_NAME=atp-platform
ATP_TELEMETRY_ENVIRONMENT=development

# OTLP exporter endpoint (e.g., http://localhost:4317)
ATP_TELEMETRY_OTLP_ENDPOINT=
ATP_TELEMETRY_CONSOLE_EXPORT=false
ATP_TELEMETRY_DEBUG_MODE=false

# ── Metrics ──────────────────────────────────────────────────

ATP_METRICS_ENABLED=false
ATP_METRICS_PREFIX=atp

# ── Container Adapter ────────────────────────────────────────

# Container runtime: docker, podman
ATP_CONTAINER_RUNTIME=docker
